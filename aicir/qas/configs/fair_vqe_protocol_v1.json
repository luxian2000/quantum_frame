{
  "protocol_version": "fair_vqe_protocol_v1",
  "frozen": true,
  "freeze_point": "after_stage0_candidate_grammar_before_first_label",
  "scope": "multi-seed final labels for VQE-QAS oracle benchmark tables",
  "hamiltonian": {
    "default_class": "tfim",
    "J": 1.0,
    "h": 0.5,
    "boundary": "OBC",
    "reference_validation": {
      "small_scale_method": "dense_diagonalization",
      "tfim_cross_check": "open_chain_free_fermion",
      "tolerance": 1e-9,
      "dtype": "float64_or_complex128"
    }
  },
  "initial_state": "|0...0>",
  "theta_initialization": {
    "mode": "random_uniform_pi",
    "range": [-3.141592653589793, 3.141592653589793],
    "zero_start": "diagnostic_only_not_allowed_in_final_ranking"
  },
  "optimizer": {
    "name": "COBYLA",
    "rhobeg": 1.0,
    "tol": 1e-6,
    "screening_maxfev": "max(500, 80 * n_params)",
    "final_maxfev": "max(1000, 200 * n_params)",
    "record_nfev": true
  },
  "label_backend": {
    "backend": "cpu_numpy",
    "dtype": "complex128",
    "note": "NPU/complex64 screening labels must not be used as final oracle labels."
  },
  "required_outputs": [
    "fair_best_energy",
    "fair_mean_energy",
    "fair_std_energy",
    "fair_success_rate",
    "delta_ref",
    "reference_energy",
    "n_seeds",
    "max_evals",
    "nfev",
    "walltime",
    "best_trace"
  ],
  "versioning_rules": [
    "Any change to optimizer, budget, backend, dtype, reference, Hamiltonian construction, or initialization requires a new protocol_version.",
    "Rows from different protocol_version values must not train or validate the same oracle."
  ]
}
